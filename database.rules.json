{
  "rules": {
    "rooms": {
      "$code": {
        "meta": {
          ".read": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
          ".write": false
        },
        "players": {
          ".read": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid && data.exists()",
            ".validate": "!newData.hasChild('isHost') || newData.child('isHost').val() === data.child('isHost').val()",
            "isHost":      { ".validate": "newData.val() === data.val()" },
            "joinedAt":    { ".validate": "newData.val() === data.val()" },
            "totalScore":  { ".validate": "newData.val() === data.val()" },
            "isReady":     { ".validate": "newData.isBoolean()" },
            "isConnected": { ".validate": "newData.isBoolean()" },
            "lastSeen":    { ".validate": "newData.isNumber()" },
            "photosReady": { ".validate": "newData.isBoolean()" }
          }
        },
        "chat": {
          ".read": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
          "$msgId": {
            ".write": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists() && newData.child('uid').val() === auth.uid",
            ".validate": "newData.hasChildren(['uid','nickname','text','ts']) && newData.child('text').val().length <= 200"
          }
        },
        "game": {
          "photoPool": {
            ".read": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
            "$uid": {
              "$index": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.hasChildren(['url','used']) && newData.child('url').isString() && newData.child('used').isBoolean()",
                "used": {
                  ".validate": "newData.val() === false"
                },
                "approved": {
                  ".validate": "!newData.exists() || newData.val() === data.val()"
                }
              }
            }
          },
          "curation": {
            ".read": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
            "votes": {
              "$ownerUid": {
                "$index": {
                  "$voterUid": {
                    ".write": "auth != null && auth.uid === $voterUid && $voterUid !== $ownerUid && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
                    ".validate": "newData.isBoolean()"
                  }
                }
              }
            },
            "ready": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
                ".validate": "newData.isBoolean()"
              }
            }
          },
          "rounds": {
            ".read": "auth != null && root.child('rooms/' + $code + '/players/' + auth.uid).exists()",
            ".write": false,
            "$n": {
              "guesses": {
                "$uid": {
                  ".write": false
                }
              }
            }
          }
        }
      }
    }
  }
}
