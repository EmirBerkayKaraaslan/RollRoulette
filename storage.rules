rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // avatars/{uid}.jpg — wildcard segmente literal (.jpg) eklenemez;
    // tam segmenti {fileName} ile yakala, sahibi {uid}.jpg kalıbıyla doğrula.
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && fileName == request.auth.uid + '.jpg';
    }

    // rooms/{code}/pool/{uid}/{index}.jpg — {uid} klasör segmenti (geçerli),
    // dosya adı {fileName} olarak yakalanır; yazma yalnız sahibine.
    match /rooms/{code}/pool/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
